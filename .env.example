# --- LLM Providers ---
# At least one of these is required for Phase 3 Semantic Analysis

# Google Gemini API Key (for gemini-1.5-flash)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (for gpt-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# --- Analysis Settings (Optional) ---
# Default results directory is .cartography inside the repo
# ANALYZE_OUTPUT_DIR=.cartography
